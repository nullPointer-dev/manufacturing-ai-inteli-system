# ============================================================
# ML / Data files
# ============================================================
# Large model artefacts – keep registry/metadata, ignore raw weights
backend/models/*.pkl
backend/models/*.h5
backend/models/*.pt
backend/models/*.onnx
backend/models/*.bin
backend/models/*.joblib

# Raw / processed data (add back specific tracked datasets with !)
backend/data/**/*.csv
backend/data/**/*.parquet
backend/data/**/*.json
backend/data/**/*.xlsx
backend/data/**/*.db
backend/data/**/*.sqlite

# Keep golden model JSON files tracked
!backend/models/golden_archive.json
!backend/models/golden_history.json
!backend/models/golden_session.json
!backend/models/model_metrics.json
!backend/models/model_versions.json
!backend/models/drift_baseline.json
!backend/models/golden_rejections.json

# MLflow / experiment tracking
mlruns/
mlartifacts/

